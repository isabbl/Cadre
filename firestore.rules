rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Templates: só usuários logados leem e escrevem
    match /templates/{id} {
      allow read, write: if request.auth != null;
    }

    // Responses: qualquer um pode criar (formulário público),
    // mas só usuários logados podem ler
    match /responses/{id} {
      allow create: if true;
      allow read: if request.auth != null;
    }
  }
}
